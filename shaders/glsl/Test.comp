#version 450
#extension GL_ARB_shading_language_include : require

#include "Common.glsl"

layout (binding = 0, rgba8) uniform image2D outImage;
layout(std140, binding = 1) readonly buffer UniformBuffer{
    mat4 camToWorld;
    ivec2 screenres;
    float time;
    int frameId;
    int vertexCount;
    int modelUniformCount;
    int totalIters;
    int dispatchDepth;
    float roughness;
    float prob_lambert;
    int enableNEE;
} uniforms;

struct ModelUniform {
    int modelType; // 0: mesh, 1: box
    mat4 model;
    mat4 modelInv;
    mat4 modelInvTranspose;
    vec3 color;
    vec3 emissive;
};

struct SurfaceIntersect{
    float t;
    vec3 pointIntersectWorld;
    vec3 baseColor;
    vec3 worldNormal;
    vec3 emissive;
    vec2 texcoord;
    int objId;
};

struct Ray {
    vec3 origin;
    vec3 direction;
};


layout(std140, binding = 2) readonly buffer PrimitiveBuffer{
    ModelUniform data[];
} primitives;

struct MeshVertices{
    vec3 Position;
    vec3 Color;
    vec2 TexCoord;
    vec3 Normal;
    vec3 TangentX;
    vec3 TangentY;
};

layout(std430, binding=3) readonly buffer MeshVerticesBuffer {
    MeshVertices Vertices[];
} b_MeshVertices;



struct BVH {
    vec3 BoxMin;
    vec3 BoxMax;
    int ChildIndex1;
    int ChildIndex2;
    int TriangleIndexStart;
    int TriangleIndexEnd;
};

layout(std430, binding=4) readonly buffer BVHBoxesBuffer {
    BVH bvhs[];
} b_BVH;

layout(binding=5) uniform sampler2D meshTex;

layout (local_size_x = 16, local_size_y = 16, local_size_z = 1) in;


#include "PathTracerImpl.glsl"

void main() 
{
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(outImage);
    uint tid = gl_GlobalInvocationID.x + gl_GlobalInvocationID.y * size.x;
    vec2 size_f = vec2(size);
    vec2 pixel_f = vec2(pixel);
    vec2 perturb = SampleXi(11223344, tid+uniforms.frameId);
    pixel_f += perturb*0.5;
    vec4 outColor = vec4(0., 0., 0., 1.);
    if(pixel.x>size.x || pixel.y > size.y){
        return;
    }
    // sensor size 32mm
    // focal length 45mm
    // fov = 2 * atan(sensor_size/2/focal_length)
    vec4 inColor = imageLoad(outImage, pixel);
    if(uniforms.frameId==0){
        imageStore(outImage, pixel, vec4(0., 0., 0., 1.));
        inColor = vec4(0. ,0., 0., 1.);
    }
    float halffov = atan(0.032/2./0.045);
    // assume our camera near plane width is 2 as in ndc.
    float cameraDistance = 1. / tan(halffov);
    float nearPlaneHeight = 2. * size_f.x / size_f.y;

    // TestSampling();
    // return;

    vec3 ndc = vec3(pixel_f.x / uniforms.screenres.x * 2 - 1, 1 - pixel_f.y / uniforms.screenres.y * 2, 0.);
    vec3 rayUnnorm = vec3(ndc.x, ndc.y / (size_f.x / size_f.y), cameraDistance);
    vec3 rayCamSpaceDir = normalize(rayUnnorm);
    rayCamSpaceDir.xyz = rayCamSpaceDir.zxy;
    rayCamSpaceDir.y *= -1.;
    mat4 camToWorld = uniforms.camToWorld;
    vec3 w_o = vec3(camToWorld * vec4(rayCamSpaceDir, 0.));
    vec4 eye_pos = camToWorld * vec4(0., 0., 0., 1.);
    vec3 rayWorldOrigin = vec3(eye_pos);
    vec3 throughput = vec3(1.0);
    vec4 worldPoint = vec4(0.0, 0.0, 0.0, 1.0);
    int lightObjIndex = 0;
    int totalIters = uniforms.dispatchDepth;
    float roughness = uniforms.roughness;
    float prob_lambert = uniforms.prob_lambert;
    
    Ray ray;
    ray.origin = rayWorldOrigin;
    ray.direction = w_o;

    SurfaceIntersect currentHit = NewSurfaceIntersect();
    RayIntersect(ray.origin, ray.direction, currentHit);

    for (int iter = 0; iter < totalIters; iter++){
        vec2 Xi = SampleXi(514., tid*(iter+1) + uniforms.frameId * totalIters);
        vec2 Xi2 = SampleXi(114., tid*(iter+1)+ uniforms.frameId * totalIters);
        vec2 Xi3 = SampleXi(1919., tid*(iter+1)+ uniforms.frameId * totalIters);
        float sample_prob = Xi3.x;
        
        if(currentHit.t > 10000.){
            break;
        }
        
        if (currentHit.emissive.x > 0.0001){
            if (iter == 0){
                outColor += vec4(throughput * currentHit.emissive, 1.0);
            }
            break;
        }

        vec3 hitPoint = ray.origin + (currentHit.t - 0.001) * ray.direction;

        if (uniforms.enableNEE != 0)
        {
            // --- 1. NEE (Light Sampling) ---
            vec3 lightDir = vec3(0., 0., 0.);
            vec3 lightNormal = vec3(0., 0., 0.);
            float pdf_light = 0.;
            bool isBlocked = false;
            SurfaceIntersect Inters_light;
            Sample_LightSourceByIndex(Xi2, lightObjIndex, hitPoint, lightDir, lightNormal, Inters_light, pdf_light, isBlocked);
            
            lightDir = normalize(lightDir);
            lightNormal = normalize(lightNormal);
            float weight_light = 0.;
            
            if (!isBlocked && pdf_light > 0.0001){
                float pdf_light_bsdf = clamp(dot(lightDir, currentHit.worldNormal), 0., 1.) / PI;
                weight_light = pow(pdf_light, 2.) / (pow(pdf_light, 2.) + pow(pdf_light_bsdf, 2.));
                if (isnan(weight_light) || isinf(weight_light)) weight_light = 0.;
            }
            
            // --- 2. BSDF Sampling ---
            vec3 bsdfDir = vec3(0., 0., 0.);
            float pdf_bsdf = 0.;
            SurfaceIntersect nextHit;

            if (sample_prob < prob_lambert){
                Sample_BSDF_Lambertian(Xi, hitPoint, currentHit.worldNormal, bsdfDir, nextHit, pdf_bsdf);
                float pdf_spec = PDF_BSDF_Specular(currentHit.worldNormal, -ray.direction, bsdfDir, roughness);
                pdf_bsdf = pdf_bsdf * prob_lambert + pdf_spec * (1. - prob_lambert);
            }
            else{
                Sample_BSDF_Specular(Xi, hitPoint, currentHit.worldNormal, -ray.direction, bsdfDir, nextHit, pdf_bsdf, roughness);
                float pdf_lambert = PDF_BSDF_Lambertian(currentHit.worldNormal, bsdfDir);
                pdf_bsdf = pdf_lambert * prob_lambert + pdf_bsdf * (1. - prob_lambert);
            }

            float weight_bsdf = 0.;
            if (pdf_bsdf > 0.0001){
                float pdf_bsdf_light = LightSquarePDF(primitives.data[lightObjIndex]) / clamp(dot(-bsdfDir, lightNormal), 0., 1.);
                if (clamp(dot(-bsdfDir, lightNormal), 0., 1.) < 0.0001){
                    pdf_bsdf_light = 0.;
                }
                if (pdf_bsdf_light > 0.){
                    weight_bsdf = pow(pdf_bsdf, 2.) / (pow(pdf_bsdf, 2.) + pow(pdf_bsdf_light, 2.));
                    if (isnan(weight_bsdf) || isinf(weight_bsdf)) weight_bsdf = 0.;
                }
            }
            
            // --- 3. Accumulation ---
            vec3 f_r_light = BSDF_CookTorrance(currentHit, -ray.direction, lightDir, roughness, 0.6);
            vec3 f_r_bsdf = BSDF_CookTorrance(currentHit, -ray.direction, bsdfDir, roughness, 0.6);

            if (pdf_light > 0.0001 && !isBlocked){
                outColor.xyz += throughput * weight_light * f_r_light * Inters_light.emissive * clamp(dot(lightDir, currentHit.worldNormal), 0., 1.) / pdf_light;
            }
            
            if (pdf_bsdf > 0.0001 && nextHit.emissive.x > 0.0001) {
                outColor.xyz += throughput * weight_bsdf * f_r_bsdf * nextHit.emissive * clamp(dot(bsdfDir, currentHit.worldNormal), 0., 1.) / pdf_bsdf;
            }
            
            // --- 4. Setup next path iteration ---
            if (pdf_bsdf > 0.0001) {
                throughput *= f_r_bsdf * clamp(dot(bsdfDir, currentHit.worldNormal), 0., 1.) / pdf_bsdf;
            } else {
                throughput = vec3(0.0);
                break;
            }

            if (any(isnan(outColor.xyz)) || any(isinf(outColor.xyz))){
                outColor.xyz = vec3(1., 0., 1.);
            }

            ray.origin = hitPoint;
            ray.direction = bsdfDir;
            currentHit = nextHit;
        }
        else
        {
            vec3 bsdfDir = vec3(0., 0., 0.);
            float pdf_bsdf = 0.;
            SurfaceIntersect nextHit;
            
            Sample_BSDF_Specular(Xi, hitPoint, currentHit.worldNormal, -ray.direction, bsdfDir, nextHit, pdf_bsdf, roughness);

            if (pdf_bsdf < 0.00001){
                outColor = vec4(0., 0., 0., 1.);
                break;
            }
            
            vec3 f_r = BSDF_CookTorrance(currentHit, -ray.direction, bsdfDir, roughness, 0.6);
            throughput *= f_r * clamp(dot(bsdfDir, currentHit.worldNormal), 0., 1.) / pdf_bsdf;
            
            ray.origin = hitPoint;
            ray.direction = bsdfDir;
            currentHit = nextHit;
            
            if (currentHit.emissive.x>0.){
                outColor.xyz = throughput * currentHit.emissive;
                break;
            }
        }
    }
    //outColor = vec4(pdf_bsdf, 0., 0., 1.);
    //outColor = vec4(currentHit.emissive, 1.);
    // if (currentHit.objId==lightObjIndex){
    //     outColor = vec4(1., 0., 1., 1.);
    // }

    // scale the outColor
    outColor.xyz *= 5.;
    if(uniforms.frameId>0 && inColor.x==inColor.x){
        outColor = mix(inColor, outColor, 1.0 / float(uniforms.frameId));
        outColor.w = 1.0;
    }
    imageStore(outImage, pixel, outColor);
}