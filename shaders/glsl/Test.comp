layout (local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

#include "Geometry.glsl"

vec2 StratifiedSample2D(uint sampleIndex, uint sqrtN, vec2 pixel, float seed)
{
    uint x = sampleIndex % sqrtN;
    uint y = sampleIndex / sqrtN;
    vec2 jitter = hash22(vec2(pixel) + float(sampleIndex) + seed);

    return (vec2(x, y) + jitter) / float(sqrtN);
}


vec2 SampleXi_Stratify(in float seed, in uint tid){
    uint sqrtN = 16;
    uint frames = uniforms.frameId;
    uint sampleIndex = Permute(frames + Permute2(tid), (sqrtN * sqrtN), 123456789);
    //uint sampleIndex = lowbias32(frames) % (sqrtN * sqrtN);
    uint sx = sampleIndex % sqrtN;
    uint sy = sampleIndex / sqrtN;
    // uint sx = gl_GlobalInvocationID.x;
    // uint sy = gl_GlobalInvocationID.y;
    // // the mod might have efficiency issues
    ivec2 size = imageSize(outImage);
    vec2 fragCoord = vec2(tid % size.x, tid / size.x);
    vec2 jitter = hash23(vec3(frames, seed+fragCoord));
    return fract((vec2(sx, sy)+jitter) / float(sqrtN));// hash23(vec3(fragCoord, seed));
}

vec2 SampleXi(in float seed, in uint tid){
    return SampleXi_Stratify(seed, tid);
    // ivec2 size = imageSize(outImage);
    // vec2 size_f = vec2(size);
    // return hash23(vec3(vec2(float(tid / size.x) / size_f.y, float(tid % size.x) / size_f.x)*500., float(uniforms.frameId)*10.) + seed);
}


// Reference: https://pbr-book.org/3ed-2018/Monte_Carlo_Integration/2D_Sampling_with_Multidimensional_Transformations#ConcentricSampleDisk
vec2 ConcentricSampleDisk(vec2 Xi){
    vec2 uOffset = 2. * Xi - vec2(1., 1.);
    if(uOffset.x==0. && uOffset.y==0.){
        return vec2(0.);
    }
    float theta, r;
    if(abs(uOffset.x) > abs(uOffset.y)){
        r = uOffset.x;
        theta = PI / 4. * (uOffset.y / uOffset.x);
    }else{
        r = uOffset.y;
        theta = PI / 2. - PI / 4. * (uOffset.x / uOffset.y);
    }
    return r * vec2(cos(theta), sin(theta));
}

// Reference: https://pbr-book.org/3ed-2018/Monte_Carlo_Integration/2D_Sampling_with_Multidimensional_Transformations
vec3 CosineSampleHemisphere(in vec2 Xi, out float pdf){
    pdf = 0.;
    vec2 d = ConcentricSampleDisk(Xi);
    float z = sqrt(max(0., 1. - d.x * d.x - d.y * d.y));
    pdf = z / PI;
    return vec3(d.x, d.y, z);
}


void TestSampling(){
    // TEST SAMPLING
    
    ivec2 size = imageSize(outImage);
    uint tid = gl_GlobalInvocationID.x + gl_GlobalInvocationID.y * size.x;
    if(tid>100 || gl_GlobalInvocationID.y > 0){
        return;
    }
    vec2 Xi = SampleXi(514., tid);
    vec2 d = ConcentricSampleDisk(Xi);
    d = d*0.5+0.5;
    vec2 size_f = vec2(512,512);
    vec2 pixel_f = d * size_f;
    ivec2 pixel = ivec2(pixel_f);
    //vec4 inColor = imageLoad(outImage, pixel);
    vec4 outColor = vec4(0., 0., 0., 1.);
    outColor = vec4(1., 1., 1., 1.);
    // outColor = mix(inColor, outColor, 1.0 / float(uniforms.frameId));
    // outColor.w = 1.0;
    imageStore(outImage, pixel, outColor);
    return;
}

void main() 
{
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(outImage);
    uint tid = gl_GlobalInvocationID.x + gl_GlobalInvocationID.y * size.x;
    vec2 size_f = vec2(size);
    vec2 pixel_f = vec2(pixel);
    vec2 perturb = SampleXi(11223344, tid+uniforms.frameId);
    pixel_f += perturb*0.5;
    vec4 outColor = vec4(0., 0., 0., 1.);
    if(pixel.x>size.x || pixel.y > size.y){
        return;
    }
    // sensor size 32mm
    // focal length 45mm
    // fov = 2 * atan(sensor_size/2/focal_length)
    vec4 inColor = imageLoad(outImage, pixel);
    if(uniforms.frameId==0){
        imageStore(outImage, pixel, vec4(0., 0., 0., 1.));
        inColor = vec4(0. ,0., 0., 1.);
    }
    float halffov = atan(0.032/2./0.045);
    // assume our camera near plane width is 2 as in ndc.
    float cameraDistance = 1. / tan(halffov);
    float nearPlaneHeight = 2. * size_f.x / size_f.y;

    // TestSampling();
    // return;

    vec3 ndc = vec3(pixel_f.x / uniforms.screenres.x * 2 - 1, 1 - pixel_f.y / uniforms.screenres.y * 2, 0.);
    vec3 rayUnnorm = vec3(ndc.x, ndc.y / (size_f.x / size_f.y), cameraDistance);
    vec3 rayCamSpaceDir = normalize(rayUnnorm);
    rayCamSpaceDir.xyz = rayCamSpaceDir.zxy;
    rayCamSpaceDir.y *= -1.;
    mat4 camToWorld = uniforms.camToWorld;
    vec3 w_o = vec3(camToWorld * vec4(rayCamSpaceDir, 0.));
    vec4 eye_pos = camToWorld * vec4(0., 0., 0., 1.);
    vec3 rayWorldOrigin = vec3(eye_pos);
    vec3 throughput = vec3(1.0);
    vec4 worldPoint = vec4(0.0, 0.0, 0.0, 1.0);
    SurfaceIntersect Intersect;
    Intersect.t = 99999.;
    Intersect.emissive = vec3(0., 0., 0.);
    Intersect.worldNormal = vec3(0., 0., 0.);
    for (int i = 0; i < 10; i++){
        vec2 Xi = SampleXi(514., tid*(i+1));
        Intersect.t = 99999.;
        RayIntersect(rayWorldOrigin, w_o, Intersect);
        if(Intersect.t>10000){
            outColor = vec4(0., 0., 0., 1.);
            break;
        }
        if (Intersect.emissive.x > 0.0001){
            outColor = vec4(throughput*Intersect.emissive * 10., 1.0);
            break;
        }
        rayWorldOrigin = rayWorldOrigin + (Intersect.t - 0.001) * w_o;
        vec3 w_i_local;
        float pdf;
        w_i_local = CosineSampleHemisphere(Xi, pdf);
        vec3 tangent_world = vec3(0., 0., 1.);
        if(length(cross(tangent_world, Intersect.worldNormal))<0.0001){
            tangent_world = vec3(0., 1., 0.);
        }
        vec3 bitangent_world = normalize(cross(Intersect.worldNormal, tangent_world));
        tangent_world = normalize(cross(bitangent_world, Intersect.worldNormal));
        vec3 w_i_world = w_i_local.x * tangent_world + w_i_local.y * bitangent_world + w_i_local.z * Intersect.worldNormal;
        if (pdf < 0.00001){
            outColor = vec4(0., 0., 0., 1.);
            break;
        }
        throughput *= Intersect.baseColor * abs(dot(w_i_world, Intersect.worldNormal));
        w_o = w_i_world;
    }
    //outColor = vec4(Intersect.t / 5., 0., 1., 1.);
    // outColor = vec4(Intersect.baseColor, 1.);
    if(uniforms.frameId>0 && inColor.x==inColor.x){
        outColor = mix(inColor, outColor, 1.0 / float(uniforms.frameId));
        outColor.w = 1.0;
    }
    imageStore(outImage, pixel, outColor);
}